{
  "rules": {
    ".read": false,
    ".write": false,
    "rooms": {
      ".read": "auth != null",
      ".indexOn": ["updatedAt"],
      "$code": {
        ".write": "auth != null && ( !data.exists() || data.child('hostId').val() === auth.uid || data.child('players').child(auth.uid).exists() || newData.child('players').child(auth.uid).exists() || (!newData.exists() && !data.child('players').exists()) )",
        "code": { ".validate": "newData.isString() && newData.val().length <= 8" },
        "status": { ".validate": "newData.isString() && (newData.val() == 'LOBBY' || newData.val() == 'PLAYING' || newData.val() == 'FINISHED')" },
        "players": {
          "$pid": {
            "name": { ".validate": "newData.isString() && newData.val().length <= 40" }
          }
        },
        "reactions": {
          "$rid": {
            "type": { ".validate": "newData.isString() && newData.val().length <= 24" },
            "fromName": { ".validate": "newData.isString() && newData.val().length <= 40" }
          }
        }
      }
    }
  }
}
